# === AgroScan Pro — variables d'environnement ===
# Copiez ce fichier en ".env" et remplissez les valeurs. Ne committez JAMAIS le .env.

ENV=development

# Base de données — SQLite par défaut ; PostgreSQL en production :
# DATABASE_URL=postgresql+psycopg://user:motdepasse@localhost:5432/agroscan
DATABASE_URL=sqlite:///./agroscan.db

# Sécurité — GÉNÉREZ une clé longue et aléatoire :
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGEZ-MOI-en-production

# Tarifs mensuels HT en FCFA
PRICE_PREMIUM_HT=5000
PRICE_COOP_HT=25000

# Paiement (Sénégal) : manuel | wave | orange_money | paydunya
PAYMENT_PROVIDER=manuel
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Moteur de conseil IA (optionnel)
ANTHROPIC_API_KEY=
